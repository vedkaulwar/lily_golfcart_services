<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Lily Golf Carts Dashboard</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🛺</text></svg>">
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#104ce4', // Reverting to a vibrant blue to match the reference image's dashboard button
                        primaryHover: '#0d3cc4',
                        secondary: '#5bc0be', 
                        mapBlue: '#3b82f6'
                    }
                }
            }
        }
    </script>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .fade-in { animation: fadeIn 0.3s ease-in-out; }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
        .auth-bg {
            background-color: #f4f8f9;
            background-image: radial-gradient(#d1d5db 1px, transparent 1px);
            background-size: 20px 20px;
        }
        input:focus, select:focus {
            outline: none;
            border-color: #104ce4;
            box-shadow: 0 0 0 1px #104ce4;
        }
        
        /* Custom Google Map InfoWindow Styling */
        .gm-style-iw.gm-style-iw-c {
            padding: 0 !important;
            border-radius: 16px !important;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05) !important;
        }
        .gm-style-iw-d {
            overflow: hidden !important;
        }
        .gm-ui-hover-effect {
            display: none !important; /* Hide default close button */
        }
    </style>
</head>
<body class="bg-gray-50 text-gray-800 antialiased min-h-screen flex flex-col font-sans">

    <!-- ==================== AUTH FLOW CONTAINER ==================== -->
    <div id="auth-flow-container" class="flex-grow flex flex-col w-full min-h-screen auth-bg md:py-10">
        <div class="w-full max-w-md mx-auto bg-white md:rounded-[2rem] md:shadow-xl flex-grow md:flex-grow-0 min-h-screen md:min-h-0 relative overflow-hidden flex flex-col">
            
            <!-- 1. SPLASH VIEW -->
            <div id="splash-view" class="flex-grow flex flex-col p-8 justify-center relative">
                <div class="mb-auto flex items-center pt-2">
                    <img src="/assets/logo.png" alt="Lily Golf Carts Logo" class="h-16 w-auto" onerror="this.style.display='none'; this.nextElementSibling.style.display='block';">
                    <span class="hidden font-bold text-primary text-xl">LILY GOLF CARTS</span>
                </div>
                <div class="mt-10 mb-2 relative z-10">
                    <h1 class="text-[28px] font-bold text-gray-900 leading-tight">Welcome to <br><span class="text-primary text-[32px]">EV Campus Services</span></h1>
                </div>
                <div class="relative flex-grow flex items-center justify-center -mx-8 my-6">
                    <img src="/assets/golf_cart.png" alt="EV Cart" class="w-full object-contain max-h-64 scale-110 drop-shadow-2xl z-10" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                    <div class="hidden w-48 h-48 bg-gray-100 rounded-full items-center justify-center text-5xl">🛺</div>
                </div>
                <div class="mt-auto space-y-4 relative z-10 pb-4">
                    <button onclick="switchAuthView('login-view', 'student')" class="w-full bg-primary hover:bg-primaryHover text-white font-semibold py-3.5 px-4 rounded-xl shadow-lg transition flex justify-center items-center">
                        Login
                    </button>
                    <button onclick="switchAuthView('signup-view', 'student')" class="w-full bg-white hover:bg-gray-50 text-primary border-2 border-primary font-semibold py-3.5 px-4 rounded-xl transition">
                        Sign Up
                    </button>
                    <div class="text-center mt-6">
                        <p class="text-[13px] text-gray-600 font-medium">Don't have an account?</p>
                        <p class="text-[13px] text-gray-600 font-medium">Create one to get started.</p>
                    </div>
                    <div class="mt-8 pt-8 border-t border-gray-200">
                        <button onclick="switchAuthView('login-view', 'driver')" class="w-full bg-gray-900 hover:bg-black text-white font-semibold py-3 px-4 rounded-xl shadow-lg transition flex justify-center items-center text-sm">
                            Drive with Lily (Partner)
                        </button>
                    </div>
                </div>
            </div>

            <!-- 2. SIGNUP VIEW -->
            <div id="signup-view" class="hidden flex-grow flex flex-col p-6">
                <button onclick="switchAuthView('splash-view')" class="flex items-center text-sm font-semibold text-gray-800 mb-6 w-fit hover:text-primary transition">
                    ← Back
                </button>
                <div class="text-center mb-6">
                    <h2 class="text-2xl font-bold text-gray-900" id="signup-title">Create Account</h2>
                    <p class="text-sm text-gray-500 mt-1">Let's get you started</p>
                </div>
                <form id="signup-form" class="space-y-4 flex-grow flex flex-col">
                    <div>
                        <label class="block text-[13px] font-semibold text-gray-800 mb-1.5">Full Name</label>
                        <input type="text" id="signup-name" required placeholder="Enter your full name" class="w-full border border-gray-200 rounded-lg p-3 text-sm transition focus:ring-1">
                    </div>
                    <div>
                        <label class="block text-[13px] font-semibold text-gray-800 mb-1.5">Mobile Number</label>
                        <div class="flex">
                            <div class="flex-shrink-0 flex items-center border border-gray-200 border-r-0 rounded-l-lg px-3 bg-white">
                                <span class="text-sm font-semibold">+91</span>
                            </div>
                            <input type="tel" id="signup-phone" required placeholder="Enter mobile number" pattern="[0-9]{10}" class="w-full border border-gray-200 rounded-r-lg p-3 text-sm transition">
                        </div>
                    </div>
                    <div id="driver-signup-fields" class="hidden">
                         <label class="block text-[13px] font-semibold text-gray-800 mb-1.5">Assign Golf Cart</label>
                         <select id="signup-cart-id" class="w-full border border-gray-200 rounded-lg p-3 text-sm transition bg-white">
                             <option value="Golf_Cart_1">Cart 1</option>
                             <option value="Golf_Cart_2">Cart 2</option>
                         </select>
                    </div>
                    <button type="submit" class="w-full bg-primary hover:bg-primaryHover text-white font-semibold py-3.5 px-4 rounded-xl shadow-lg transition mt-4 text-[15px]">
                        Send OTP
                    </button>
                    <div class="mt-auto pt-4 text-center text-[13px]">
                        <p class="text-gray-600 mb-3">Already have an account? <button type="button" onclick="switchAuthView('login-view', currentAuthRole)" class="text-primary font-bold hover:underline">Login</button></p>
                    </div>
                </form>
            </div>

            <!-- 3. LOGIN VIEW -->
            <div id="login-view" class="hidden flex-grow flex flex-col p-6">
                <button onclick="switchAuthView('splash-view')" class="flex items-center text-sm font-semibold text-gray-800 mb-8 w-fit hover:text-primary transition">
                    ← Back
                </button>
                <div class="text-center mb-8">
                    <h2 class="text-2xl font-bold text-gray-900" id="login-title">Welcome Back</h2>
                    <p class="text-sm text-gray-500 mt-1">Log in to continue</p>
                </div>
                <form id="login-form" class="space-y-5 flex-grow flex flex-col">
                    <div>
                        <label class="block text-[13px] font-semibold text-gray-800 mb-1.5">Mobile Number</label>
                        <div class="flex">
                            <div class="flex-shrink-0 flex items-center border border-gray-200 border-r-0 rounded-l-lg px-3 bg-white">
                                <span class="text-sm font-semibold">+91</span>
                            </div>
                            <input type="tel" id="login-phone" required placeholder="Enter mobile number" pattern="[0-9]{10}" class="w-full border border-gray-200 rounded-r-lg p-3 text-sm transition">
                        </div>
                    </div>
                    <button type="submit" class="w-full bg-primary hover:bg-primaryHover text-white font-semibold py-3.5 px-4 rounded-xl shadow-lg transition mt-2 text-[15px]">
                        Send OTP
                    </button>
                    <div class="mt-auto pt-4 pb-2 text-center text-[13px]">
                        <p class="text-gray-600">New user? <button type="button" onclick="switchAuthView('signup-view', currentAuthRole)" class="text-primary font-bold hover:underline">Sign Up</button></p>
                    </div>
                </form>
            </div>

            <!-- 4. OTP VIEW -->
            <div id="otp-view" class="hidden flex-grow flex flex-col p-6">
                <button onclick="switchAuthView('login-view', currentAuthRole)" class="flex items-center text-sm font-semibold text-gray-800 mb-8 w-fit hover:text-primary transition">
                    ← Back
                </button>
                <div class="text-center mb-8">
                    <h2 class="text-2xl font-bold text-gray-900">Verify Mobile Number</h2>
                    <p class="text-sm text-gray-500 mt-1">Enter the 6-digit OTP sent to<br><span id="otp-phone-display" class="font-bold text-primary">+91 XXXXX XXXXX</span></p>
                </div>
                <form id="otp-form" class="space-y-6 flex-grow flex flex-col">
                    <div class="flex justify-between space-x-2">
                        <input type="text" maxlength="1" class="w-12 h-12 text-center text-xl font-bold border border-gray-300 rounded-lg focus:border-primary transition">
                        <input type="text" maxlength="1" class="w-12 h-12 text-center text-xl font-bold border border-gray-300 rounded-lg focus:border-primary transition">
                        <input type="text" maxlength="1" class="w-12 h-12 text-center text-xl font-bold border border-gray-300 rounded-lg focus:border-primary transition">
                        <input type="text" maxlength="1" class="w-12 h-12 text-center text-xl font-bold border border-gray-300 rounded-lg focus:border-primary transition">
                        <input type="text" maxlength="1" class="w-12 h-12 text-center text-xl font-bold border border-gray-300 rounded-lg focus:border-primary transition">
                        <input type="text" maxlength="1" class="w-12 h-12 text-center text-xl font-bold border border-gray-300 rounded-lg focus:border-primary transition">
                    </div>
                    <button type="submit" class="w-full bg-primary hover:bg-primaryHover text-white font-semibold py-3.5 px-4 rounded-xl shadow-lg transition text-[15px]">
                        Verify OTP
                    </button>
                </form>
            </div>
        </div>
    </div>
    <div id="recaptcha-container"></div>

    <!-- ==================== MAIN DASHBOARD CONTAINER ==================== -->
    <div id="main-app-container" class="hidden h-screen bg-gray-50 w-full flex flex-col overflow-hidden relative">
        
        <!-- HEADER (Floating) -->
        <header class="absolute top-0 left-0 right-0 h-20 bg-white/90 backdrop-blur-md shadow-sm flex items-center justify-between px-6 z-20">
            <div class="flex items-center space-x-3">
                <button onclick="toggleDrawer()" class="p-2 -ml-2 text-gray-700 hover:bg-gray-100 rounded-full transition">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
                </button>
                <div>
                    <h2 class="text-lg md:text-xl font-bold text-gray-900 tracking-tight leading-tight">Hello <span id="user-greeting-name">Student</span> 👋</h2>
                    <p class="text-gray-500 text-xs md:text-sm">Need a ride?</p>
                </div>
            </div>
            <div class="flex items-center space-x-4">
                <div class="relative cursor-pointer">
                    <div class="p-2 bg-gray-50 rounded-full shadow-sm border border-gray-100 text-gray-500 hover:text-primary transition">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path></svg>
                    </div>
                    <span class="absolute top-0 right-0 w-2 h-2 bg-primary rounded-full border-2 border-white"></span>
                </div>
                <div class="w-10 h-10 rounded-full bg-primary/10 text-primary flex items-center justify-center font-bold overflow-hidden shadow-sm">
                    <img src="https://ui-avatars.com/api/?name=User&background=104ce4&color=fff" id="user-avatar" alt="Avatar" class="w-full h-full object-cover">
                </div>
            </div>
        </header>

        <!-- DASHBOARD VIEWS -->
        <main class="flex-1 w-full h-full relative">
            
                <!-- STUDENT VIEW -->
            <!-- STUDENT VIEW -->
            <div id="student-dashboard-view" class="hidden absolute inset-0 flex flex-col">
                <!-- Overlay Alerts -->
                <div id="student-active-ride-section" class="hidden absolute top-24 left-1/2 transform -translate-x-1/2 z-20 w-[90%] max-w-sm bg-gradient-to-r from-emerald-500 to-teal-500 rounded-2xl shadow-xl p-5 text-white">
                    <div class="flex justify-between items-center mb-2">
                        <h3 class="font-bold text-lg">Ride Confirmed! 🛺</h3>
                        <span class="bg-white text-emerald-600 text-xs font-bold px-2.5 py-1 rounded-full">Active</span>
                    </div>
                    <p class="text-sm text-emerald-50 mb-3">Show this OTP to your driver.</p>
                    <div class="bg-white/20 backdrop-blur-md rounded-xl p-3 text-center border border-white/30">
                        <p class="text-[10px] text-emerald-50 uppercase tracking-widest font-bold mb-1">OTP</p>
                        <p id="student-ride-otp" class="text-3xl font-bold tracking-widest text-white">----</p>
                    </div>
                </div>

                <div id="student-ride-ended-section" class="hidden absolute top-24 left-1/2 transform -translate-x-1/2 z-20 w-[90%] max-w-sm bg-white rounded-2xl shadow-xl p-5 text-center border border-gray-100">
                    <div class="w-12 h-12 bg-emerald-100 rounded-full flex items-center justify-center text-emerald-500 text-2xl mx-auto mb-3">✓</div>
                    <h3 class="font-bold text-gray-900 mb-1">Ride Completed</h3>
                    <p class="text-sm text-gray-500 mb-4">Thank you for traveling with us.</p>
                    <button onclick="document.getElementById('student-ride-ended-section').classList.add('hidden')" class="bg-gray-100 text-gray-700 font-bold py-2 px-6 rounded-lg shadow-sm hover:bg-gray-200 transition w-full text-sm">Dismiss</button>
                </div>

                <!-- Fullscreen Map -->
                <div id="student-map" class="absolute inset-0 bg-gray-200">
                    <div class="absolute inset-0 flex items-center justify-center text-gray-500 text-sm font-medium">Loading Interactive Map...</div>
                </div>

                <!-- Available Carts Sliding Panel (Overlays above bottom bar) -->
                <div id="available-carts-section" class="hidden absolute bottom-[240px] md:bottom-[120px] left-4 right-4 md:left-auto md:right-8 md:w-96 bg-white rounded-2xl shadow-2xl border border-gray-100 p-5 z-20 max-h-64 flex flex-col fade-in">
                    <div class="flex justify-between items-center mb-4">
                        <h3 class="font-bold text-gray-900">Available Carts <span class="text-xs bg-emerald-100 text-emerald-600 px-2 py-1 rounded-full ml-2">Live</span></h3>
                        <button onclick="document.getElementById('available-carts-section').classList.add('hidden')" class="text-gray-400 hover:text-gray-800 transition">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                        </button>
                    </div>
                    <div id="carts-list" class="flex-1 overflow-y-auto space-y-3 pr-2">
                        <!-- Carts dynamically injected here -->
                    </div>
                </div>

                <!-- Bottom Book a Ride Bar (Mobile docked, Desktop floating) -->
                <div id="book-ride-bar" class="absolute bottom-0 w-full md:w-[600px] md:bottom-8 md:left-1/2 md:transform md:-translate-x-1/2 bg-white rounded-t-3xl md:rounded-3xl shadow-[0_-8px_30px_rgb(0,0,0,0.12)] md:shadow-2xl p-6 border-t md:border border-gray-100 z-10 pb-8 md:pb-6">
                    <h3 class="font-bold text-gray-900 mb-4 hidden md:block">Book a Ride</h3>
                    <div class="flex flex-col space-y-3">
                        <div class="flex items-center space-x-3">
                            <div class="w-2.5 h-2.5 rounded-full border-2 border-primary shrink-0"></div>
                            <select id="pickup-hub" class="flex-1 border border-gray-200 rounded-xl py-3 px-4 text-sm text-gray-700 bg-gray-50 focus:bg-white focus:ring-2 focus:ring-primary/20 transition appearance-none">
                                <option value="" disabled selected>Select pickup location</option>
                            </select>
                        </div>
                        <div class="flex items-center space-x-3">
                            <div class="w-2.5 h-2.5 rounded-full border-2 border-gray-800 shrink-0"></div>
                            <select id="dropoff-hub" class="flex-1 border border-gray-200 rounded-xl py-3 px-4 text-sm text-gray-700 bg-gray-50 focus:bg-white focus:ring-2 focus:ring-primary/20 transition appearance-none">
                                <option value="" disabled selected>Select drop location</option>
                            </select>
                        </div>
                        <button id="btn-find-carts" class="w-full bg-primary hover:bg-primaryHover text-white font-bold py-3.5 px-6 rounded-xl shadow-md transition text-[15px] mt-2">
                            Find Available Carts
                        </button>
                    </div>
                </div>
            </div>

                <!-- DRIVER VIEW -->
            <!-- DRIVER VIEW -->
            <div id="driver-dashboard-view" class="hidden absolute inset-0 flex flex-col md:flex-row">
                
                <!-- Map Background -->
                <div id="driver-map" class="absolute inset-0 bg-gray-200 z-0">
                    <div class="absolute inset-0 flex items-center justify-center text-gray-500 text-sm font-medium">Loading Map...</div>
                </div>

                <!-- Floating Requests Panel -->
                <div class="absolute bottom-0 w-full md:w-96 md:h-auto md:top-24 md:bottom-8 md:left-8 bg-white rounded-t-3xl md:rounded-3xl shadow-2xl border-t md:border border-gray-100 flex flex-col overflow-hidden z-10 max-h-[60vh] md:max-h-none">
                    <div class="bg-gray-900 p-5 text-white shrink-0">
                        <div class="flex justify-between items-center mb-4">
                            <div>
                                <h2 class="text-xl font-bold" id="driver-cart-display">Cart #01</h2>
                            </div>
                            <label class="relative inline-flex items-center cursor-pointer">
                                <input type="checkbox" id="toggle-duty" class="sr-only peer">
                                <div class="w-12 h-6 bg-gray-700 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-emerald-500"></div>
                            </label>
                        </div>
                        <p id="driver-status-text" class="text-gray-400 font-semibold text-sm">Offline - Toggle to receive rides</p>
                    </div>
                    <div class="p-5 flex-1 overflow-y-auto bg-gray-50">
                        <h3 class="font-bold text-gray-800 text-sm uppercase tracking-wider mb-4">Live Requests</h3>
                        <div id="ride-requests-container" class="space-y-4">
                            <div id="no-requests-text" class="text-center text-gray-400 py-10 bg-white rounded-xl border border-dashed border-gray-200">
                                <p class="font-medium text-sm">No active requests.</p>
                            </div>
                        </div>
                    </div>
                </div>

            </div>

        </main>

        <!-- NAVIGATION DRAWER (Slide-Out Sidebar) -->
        <div id="nav-drawer" class="fixed inset-y-0 left-0 w-72 bg-white shadow-2xl z-50 transform -translate-x-full transition-transform duration-300 ease-in-out flex flex-col">
            <div class="p-6 bg-gray-50 flex items-center justify-between border-b border-gray-100">
                <div class="flex items-center space-x-3">
                    <div class="w-12 h-12 rounded-full bg-primary/10 text-primary flex items-center justify-center font-bold overflow-hidden">
                        <img src="https://ui-avatars.com/api/?name=User&background=104ce4&color=fff" id="drawer-avatar" class="w-full h-full object-cover">
                    </div>
                    <div>
                        <h3 class="font-bold text-gray-900" id="drawer-name">User Name</h3>
                        <p class="text-xs text-gray-500" id="drawer-phone">+91 0000000000</p>
                    </div>
                </div>
                <button onclick="toggleDrawer()" class="p-2 text-gray-400 hover:text-gray-800 bg-white rounded-full shadow-sm">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            <nav class="flex-1 overflow-y-auto py-4">
                <a href="#" id="link-home" onclick="openOverlayView('home')" class="flex items-center px-6 py-4 text-gray-700 hover:bg-gray-50 hover:text-primary font-medium transition">
                    <svg class="w-5 h-5 mr-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
                    Home
                </a>
                <a href="#" id="link-history" onclick="openOverlayView('history-view')" class="flex items-center px-6 py-4 text-gray-700 hover:bg-gray-50 hover:text-primary font-medium transition">
                    <svg class="w-5 h-5 mr-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    My Rides
                </a>
                <a href="#" id="link-wallet" onclick="openOverlayView('wallet-view')" class="flex items-center px-6 py-4 text-gray-700 hover:bg-gray-50 hover:text-primary font-medium transition">
                    <svg class="w-5 h-5 mr-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path></svg>
                    Wallet
                </a>
                <a href="#" id="link-profile" onclick="openOverlayView('profile-view')" class="flex items-center px-6 py-4 text-gray-700 hover:bg-gray-50 hover:text-primary font-medium transition">
                    <svg class="w-5 h-5 mr-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                    Profile
                </a>
            </nav>
            <div class="p-4 border-t border-gray-100">
                <button onclick="logout()" class="w-full flex items-center px-4 py-3 text-red-500 hover:bg-red-50 rounded-xl font-medium transition">
                    <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
                    Logout
                </button>
            </div>
        </div>
        <!-- DRAWER BACKDROP -->
        <div id="nav-drawer-backdrop" onclick="toggleDrawer()" class="hidden fixed inset-0 bg-gray-900/50 backdrop-blur-sm z-40 transition-opacity"></div>

        <!-- OVERLAY VIEWS -->
        <div id="overlay-views-container" class="hidden absolute inset-0 z-30 bg-gray-50 flex flex-col slide-in-right">
            <!-- Overlay Header -->
            <header class="h-16 bg-white shadow-sm flex items-center px-4 shrink-0">
                <button onclick="closeOverlayView()" class="p-2 mr-2 text-gray-600 hover:bg-gray-100 rounded-full">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                </button>
                <h2 class="text-lg font-bold text-gray-900 flex-1" id="overlay-title">Title</h2>
            </header>

            <!-- Wallet View -->
            <div id="wallet-view" class="hidden flex-1 overflow-y-auto p-6 bg-white">
                <div class="bg-gradient-to-br from-gray-900 to-gray-800 rounded-3xl p-6 text-white mb-8 shadow-xl shadow-gray-900/20 max-w-sm mx-auto">
                    <p class="text-gray-400 text-sm font-medium mb-1">Available Balance</p>
                    <h3 class="text-4xl font-bold" id="wallet-balance-display">₹0.00</h3>
                    <div class="mt-8">
                        <button onclick="addFunds(100)" class="w-full bg-white text-gray-900 font-bold py-3 px-4 rounded-xl text-sm hover:bg-gray-100 transition shadow-sm">
                            + Add ₹100
                        </button>
                    </div>
                </div>
                <div class="max-w-sm mx-auto">
                    <h4 class="font-bold text-gray-800 mb-4 px-1">Recent Transactions</h4>
                    <div class="space-y-3" id="wallet-transactions-list">
                        <!-- Transactions dynamically loaded -->
                    </div>
                </div>
            </div>

            <!-- History View -->
            <div id="history-view" class="hidden flex-1 overflow-y-auto p-6 bg-white">
                <div class="max-w-md mx-auto space-y-4" id="ride-history-list">
                    <!-- History dynamically loaded -->
                </div>
            </div>

            <!-- Profile View -->
            <div id="profile-view" class="hidden flex-1 overflow-y-auto p-6 bg-white">
                <div class="max-w-md mx-auto space-y-6">
                    <div class="flex flex-col items-center mb-8">
                        <div class="w-24 h-24 rounded-full bg-primary/10 flex items-center justify-center overflow-hidden mb-4 ring-4 ring-gray-50">
                            <img src="https://ui-avatars.com/api/?name=User&background=104ce4&color=fff" id="profile-edit-avatar" class="w-full h-full object-cover">
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-2">Full Name</label>
                        <input type="text" id="profile-edit-name" class="w-full border border-gray-200 rounded-xl p-3 text-sm focus:border-primary focus:ring-1 focus:ring-primary outline-none transition">
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-2">Mobile Number (Read Only)</label>
                        <input type="text" id="profile-edit-phone" class="w-full border border-gray-200 rounded-xl p-3 text-sm bg-gray-50 text-gray-500 cursor-not-allowed" readonly>
                    </div>
                    <button onclick="saveProfile()" class="w-full bg-primary text-white font-bold py-3.5 px-6 rounded-xl hover:bg-primaryHover transition shadow-lg shadow-primary/30 mt-4">
                        Save Changes
                    </button>
                </div>
            </div>

        </div>

    </div>

    <!-- SEAT SELECTION MODAL (Overlays on top) -->
    <div id="seat-selection-view" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-gray-900/40 backdrop-blur-sm">
        <div class="bg-white rounded-[2rem] shadow-2xl p-8 max-w-md w-full relative">
            <button id="btn-back-dashboard" class="absolute top-6 left-6 text-gray-400 hover:text-gray-800 transition">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
            
            <div class="text-center mb-8 mt-2">
                <h2 class="text-2xl font-bold text-gray-900" id="booking-cart-name">Golf Cart</h2>
                <p class="text-sm text-gray-500 mt-1">Select an available seat</p>
            </div>

            <div class="bg-gray-50 border border-gray-100 rounded-2xl p-6 pb-10 relative mx-auto mb-8" style="max-width: 280px;">
                <div class="w-16 h-2 bg-gray-300 rounded-full mx-auto mb-6"></div>
                <div class="grid grid-cols-2 gap-4">
                    <div class="h-16 flex items-center justify-center rounded-xl bg-gray-200 text-gray-500 font-bold text-sm cursor-not-allowed">Driver</div>
                    <div id="seat-2" class="h-16 flex items-center justify-center rounded-xl font-bold text-sm cursor-pointer transition border-2" onclick="toggleSeat(2)">Seat 2</div>
                    <div id="seat-3" class="h-16 flex items-center justify-center rounded-xl font-bold text-sm cursor-pointer transition border-2" onclick="toggleSeat(3)">Seat 3</div>
                    <div id="seat-4" class="h-16 flex items-center justify-center rounded-xl font-bold text-sm cursor-pointer transition border-2" onclick="toggleSeat(4)">Seat 4</div>
                    <div id="seat-5" class="h-16 flex items-center justify-center rounded-xl font-bold text-sm cursor-pointer transition border-2" onclick="toggleSeat(5)">Seat 5</div>
                    <div id="seat-6" class="h-16 flex items-center justify-center rounded-xl font-bold text-sm cursor-pointer transition border-2" onclick="toggleSeat(6)">Seat 6</div>
                </div>
            </div>

            <button id="btn-confirm-booking" disabled class="w-full bg-primary text-white font-bold py-3.5 px-4 rounded-xl shadow-lg shadow-primary/30 transition text-[15px] opacity-50 cursor-not-allowed">
                Confirm Booking
            </button>
        </div>
    </div>

    <script src="/socket.io/socket.io.js"></script>
    <script>
        window.initMap = function() {
            window.mapReady = true;
            if (window.appInitMap) window.appInitMap();
        };
    </script>
    <script type="module" src="/js/app.js"></script>
    <!-- Google Maps API -->
    <script src="https://maps.googleapis.com/maps/api/js?key=AIzaSyBdCydQHhoW9S2pt0NN68pu5JPg1xE0kdo&callback=initMap&loading=async" async defer></script>
</body>
</html>
